# ─── ENTORNO ──────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── BASE DE DATOS ────────────────────────────────────────────────────────────
# Opción A: Cadena de conexión completa (recomendada para servicios cloud)
DATABASE_URL=postgresql://usuario:password@host:5432/olympus_core

# Opción B: Variables separadas (para PostgreSQL local)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=olympus_core
DB_USER=postgres
DB_PASSWORD=tu_password_aqui

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Genera una clave larga y aleatoria (mínimo 32 caracteres)
JWT_SECRET=cambia_esto_por_una_clave_muy_larga_y_segura_minimo_32chars
JWT_EXPIRES_IN=24h

# ─── SEGURIDAD QR ─────────────────────────────────────────────────────────────
QR_SECRET=clave_secreta_para_firmar_tokens_qr

# ─── LOGIN ────────────────────────────────────────────────────────────────────
MAX_LOGIN_ATTEMPTS=5
LOGIN_BLOCK_MINUTES=30

# ─── CORS ─────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
